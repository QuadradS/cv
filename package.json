{
  "name": "cv",
  "version": "1.0.0",
  "private": true,
  "description": "Data-driven static CV. Content in JSON, HTML from Handlebars templates, screen + ATS-safe print views, PDF via Puppeteer.",
  "homepage": "https://quadrads.github.io/cv",
  "scripts": {
    "dev": "webpack serve --mode development",
    "build:html": "webpack --mode production",
    "build:pdf": "node scripts/build-pdf.js",
    "build": "npm run build:html && npm run build:pdf",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "devDependencies": {
    "copy-webpack-plugin": "^12.0.2",
    "gh-pages": "^6.3.0",
    "css-loader": "^7.1.2",
    "handlebars": "^4.7.8",
    "handlebars-loader": "^1.7.3",
    "html-webpack-plugin": "^5.6.3",
    "mini-css-extract-plugin": "^2.9.2",
    "puppeteer": "^24.10.0",
    "sass": "^1.83.0",
    "sass-loader": "^16.0.4",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0"
  }
}
