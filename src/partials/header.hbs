<header class="header">
  {{#if basics.photo}}
    <img class="header__photo" src="{{basics.photo}}" alt="{{basics.name}}" />
  {{/if}}
  <h1 class="header__name">{{basics.name}}</h1>
  <p class="header__title">{{basics.title}}</p>
  <p class="header__location">
    {{basics.location}}{{#if basics.openToRemote}} · {{labels.openToRemote}}{{/if}}
  </p>
  <ul class="header__contacts">
    <li>
      <a href="{{basics.contacts.telegram.url}}" target="_blank" rel="noopener">
        <svg class="header__icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M9.78 18.65l.28-4.23 7.68-6.92c.34-.31-.07-.46-.52-.19L7.74 13.3 3.64 12c-.88-.25-.89-.86.2-1.3l15.97-6.16c.73-.33 1.43.18 1.15 1.3l-2.72 12.81c-.19.91-.74 1.13-1.5.71L12.6 16.3l-1.99 1.93c-.23.23-.42.42-.83.42z"/></svg>
        <span>{{basics.contacts.telegram.label}}</span>
      </a>
    </li>
    <li>
      <a href="{{basics.contacts.github.url}}" target="_blank" rel="noopener">
        <svg class="header__icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .5C5.37.5 0 5.78 0 12.29c0 5.21 3.44 9.63 8.2 11.19.6.11.82-.25.82-.57v-2c-3.34.72-4.04-1.6-4.04-1.6-.55-1.36-1.34-1.72-1.34-1.72-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.21 1.84 1.21 1.07 1.8 2.81 1.28 3.5.98.11-.76.42-1.28.76-1.57-2.67-.3-5.47-1.31-5.47-5.84 0-1.29.47-2.34 1.24-3.17-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.21.96-.26 1.98-.39 3-.4 1.02 0 2.04.14 3 .4 2.28-1.53 3.29-1.21 3.29-1.21.66 1.66.24 2.88.12 3.18.77.83 1.23 1.88 1.23 3.17 0 4.54-2.81 5.54-5.48 5.83.43.36.81 1.08.81 2.18v3.23c0 .32.21.69.82.57A11.8 11.8 0 0024 12.29C24 5.78 18.63.5 12 .5z"/></svg>
        <span>{{basics.contacts.github.label}}</span>
      </a>
    </li>
    <li>
      <a href="mailto:{{basics.contacts.email}}">
        <svg class="header__icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2zm0 2v.4l8 5 8-5V6H4zm16 2.75l-8 5-8-5V18h16V8.75z"/></svg>
        <span>{{basics.contacts.email}}</span>
      </a>
    </li>
  </ul>
</header>
