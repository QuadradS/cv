<!DOCTYPE html>
<html lang="{{lang}}">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{basics.name}} — {{basics.title}}</title>
  <meta name="description" content="{{basics.name}} — {{basics.title}}. {{basics.location}}." />
  <link rel="preload" href="./assets/fonts/InterVariable.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="icon" href="./assets/favicon.png" />
</head>
<body>
  <a class="lang-switch" href="{{labels.altUrl}}">{{labels.altLabel}}</a>
  <button type="button" class="print-btn" data-print aria-label="{{labels.print}}">{{labels.print}}</button>

  <main class="cv">
    <aside class="cv__sidebar">
      {{> header}}
      {{> skills}}
      {{> languages}}
    </aside>

    <section class="cv__main">
      {{> summary}}
      {{> experience}}
    </section>
  </main>
</body>
</html>
